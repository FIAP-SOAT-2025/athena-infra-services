{
  "dashboard": {
    "id": null,
    "uid": "athena-videoprocessor",
    "title": "Athena Videoprocessor Overview",
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Target Up",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "up{service=\"videoprocessor-service\",namespace=\"athena-tc5\"}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "CPU Usage (cores)",
        "gridPos": {
          "h": 8,
          "w": 9,
          "x": 6,
          "y": 0
        },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{service=\"videoprocessor-service\",namespace=\"athena-tc5\"}[5m])",
            "legendFormat": "cpu",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "Resident Memory (bytes)",
        "gridPos": {
          "h": 8,
          "w": 9,
          "x": 15,
          "y": 0
        },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{service=\"videoprocessor-service\",namespace=\"athena-tc5\"}",
            "legendFormat": "rss",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "Event Loop Lag (seconds)",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "nodejs_eventloop_lag_seconds{service=\"videoprocessor-service\",namespace=\"athena-tc5\"}",
            "legendFormat": "lag",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Open File Descriptors",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "process_open_fds{service=\"videoprocessor-service\",namespace=\"athena-tc5\"}",
            "legendFormat": "open_fds",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Heap Size (bytes)",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "process_heap_bytes{service=\"videoprocessor-service\",namespace=\"athena-tc5\"}",
            "legendFormat": "heap",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
